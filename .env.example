# API
API_PORT=3001
SP_NAME=dbo.encuestaCargaSorteo01
# 2do paso: @telefono, @encuesta, @campo5Valor..@campo8Valor
SP_INTERVIEW_NAME=dbo.encuestaActualizaEntrevistaSorteo01
ENCUESTA_TABLE_NAME=encuesta

# Teléfono del supervisor y domicilio de sucursal no se configuran acá: el servidor
# que arma el link de WhatsApp los agrega como query params, p. ej.:
#   supervisorCelular=5493705032010
#   supervisorSucursalDireccion=FOTHERNINGHAM%2010989
# Otros alias soportados: ver CLAVES_TELEFONO_SUPERVISOR y CLAVES_DOMICILIO_SUCURSAL en src/App.tsx.

# SQL Server (equivale a una cadena OLE DB tipo SQLOLEDB)
# Data Source  -> DB_HOST + DB_PORT (ej. 190.106.131.63 y 1433)
# Initial Catalog -> DB_NAME
# User ID -> DB_USER
# Password -> DB_PASSWORD
#
# OLE DB de referencia (solo documentacion; copiar valores a tu .env local):
# Provider=SQLOLEDB.1;...;Initial Catalog=TU_BASE;Data Source=TU_HOST,1433

DB_HOST=TU_HOST_SQL
DB_PORT=1433
DB_NAME=TU_BASE
DB_USER=TU_USUARIO_SQL
DB_PASSWORD=TU_PASSWORD_SQL

# Para servidor sin TLS obligatorio suele ir encrypt=false.
DB_ENCRYPT=false
# Si el certificado del servidor no es de una CA confiable, suele ir true en dev.
DB_TRUST_CERT=true
