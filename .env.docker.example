# Copiar en el VPS: cp .env.docker.example .env  →  nano .env

# Dominio (sin https://). Debe apuntar por DNS A a la IP del VPS.
ENCUESTA_HOST=miprimercasafsa-sorteo.com

# API / SQL Server (misma BD que Render)
SP_NAME=dbo.encuestaCargaSorteo01
DB_HOST=TU_HOST_SQL
DB_PORT=1433
DB_NAME=TU_BASE
DB_USER=TU_USUARIO
DB_PASSWORD=TU_PASSWORD
DB_ENCRYPT=false
DB_TRUST_CERT=true
