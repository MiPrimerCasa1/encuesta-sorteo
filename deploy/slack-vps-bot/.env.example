# Copiar a deploy/slack-vps-bot/.env en el VPS (no commitear).
# Opción A (recomendada): Basic Information → Signing Secret
SLACK_SIGNING_SECRET=

# Opción B: Slash Commands → /vps → Verification Token (legacy, más simple)
# SLACK_VERIFICATION_TOKEN=

# Opcional: ID del workspace (team_id) para limitar quién puede usar /vps
# SLACK_TEAM_ID=T00000000
